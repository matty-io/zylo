#!/bin/sh
# Maven wrapper script - downloads Maven if necessary and runs it

set -e

MAVEN_HOME="${MAVEN_HOME:-$HOME/.m2/wrapper}"
MAVEN_VERSION="3.9.6"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/${MAVEN_VERSION}/apache-maven-${MAVEN_VERSION}-bin.tar.gz"

if [ ! -d "${MAVEN_HOME}/apache-maven-${MAVEN_VERSION}" ]; then
    echo "Downloading Maven ${MAVEN_VERSION}..."
    mkdir -p "${MAVEN_HOME}"
    curl -sL "${MAVEN_URL}" | tar xz -C "${MAVEN_HOME}"
fi

exec "${MAVEN_HOME}/apache-maven-${MAVEN_VERSION}/bin/mvn" "$@"
